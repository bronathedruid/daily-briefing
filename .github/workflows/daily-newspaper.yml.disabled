name: Daily Newspaper Update

on:
  schedule:
    # Run at 6am EST (11:00 UTC), 12pm EST (17:00 UTC), and 6pm EST (23:00 UTC)
    - cron: '0 11 * * *'  # Morning edition
    - cron: '0 17 * * *'  # Afternoon edition  
    - cron: '0 23 * * *'  # Evening edition
  workflow_dispatch: # Manual trigger

permissions:
  contents: write
  pages: write
  id-token: write

concurrency:
  group: "pages"
  cancel-in-progress: false

env:
  NODE_VERSION: '22'

jobs:
  fetch-and-build:
    runs-on: ubuntu-latest
    timeout-minutes: 15
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: ${{ env.NODE_VERSION }}
          cache: 'npm'

      - name: Install dependencies
        run: |
          npm ci
          # Install serve for development testing
          npm install --save-dev serve

      - name: Make scripts executable
        run: |
          chmod +x scripts/enhanced-fetch-news.mjs
          chmod +x scripts/generate-newspaper.mjs

      - name: Fetch and process news
        run: |
          echo "🔍 Fetching RSS feeds..."
          npm run fetch
        timeout-minutes: 8
        env:
          # Add any API keys here if needed
          # OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}

      - name: Generate newspaper website
        run: |
          echo "📰 Generating newspaper layout..."
          npm run build

      - name: Verify build output
        run: |
          echo "✅ Checking generated files..."
          ls -la public/
          echo "📊 File sizes:"
          du -h public/*
          echo "📄 HTML size:"
          wc -c public/index.html

      - name: Generate ACE Music daily song
        run: |
          echo "🎵 Generating daily AI song..."
          # Generate a daily song using ACE Music
          if command -v ace-music >/dev/null 2>&1; then
            ace-music generate "Tech news briefing ambient instrumental" --duration 60 --output public/daily-song.mp3 || echo "⚠️ Music generation failed"
          else
            echo "⚠️ ACE Music not available, skipping song generation"
          fi

      - name: Optimize images and assets
        run: |
          echo "🖼️ Optimizing assets..."
          # Add image optimization if needed
          find public/ -name "*.html" -exec gzip -k9 {} \;
          echo "📦 Compressed files:"
          ls -la public/*.gz || echo "No compressed files"

      - name: Commit and push changes
        run: |
          git config user.name "Daily Briefing Bot"
          git config user.email "bot@daily-briefing.local"
          git add data/ public/
          
          # Check if there are changes to commit
          if git diff --staged --quiet; then
            echo "📰 No changes to commit"
          else
            # Create edition-specific commit message
            EDITION="Evening"
            if [ $(date -u +%H) -eq 11 ]; then
              EDITION="Morning"
            elif [ $(date -u +%H) -eq 17 ]; then
              EDITION="Afternoon"  
            fi
            
            git commit -m "📰 $EDITION Edition - $(date -u +%Y-%m-%d)"
            git push
            echo "✅ Pushed $EDITION edition updates"
          fi

  deploy:
    needs: fetch-and-build
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    steps:
      - name: Checkout latest changes
        uses: actions/checkout@v4
        with:
          ref: main

      - name: Setup Pages
        uses: actions/configure-pages@v5
        with:
          # Enable static file compression
          enablement: true

      - name: Upload artifact
        uses: actions/upload-pages-artifact@v3
        with:
          path: 'public'

      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4
        with:
          timeout: 300000  # 5 minutes

      - name: Notify deployment status
        run: |
          EDITION="Evening"
          if [ $(date -u +%H) -eq 11 ]; then
            EDITION="Morning"
          elif [ $(date -u +%H) -eq 17 ]; then
            EDITION="Afternoon"  
          fi
          
          echo "🚀 $EDITION Edition deployed successfully!"
          echo "📰 Available at: ${{ steps.deployment.outputs.page_url }}"

  # Health check job
  health-check:
    needs: deploy
    runs-on: ubuntu-latest
    if: always()
    steps:
      - name: Check website health
        run: |
          echo "🏥 Performing health check..."
          
          # Wait a moment for deployment to propagate
          sleep 30
          
          # Check if the site is accessible
          if curl -sf "${{ needs.deploy.outputs.page_url || 'https://bronathedruid.github.io/daily-briefing/' }}" > /dev/null; then
            echo "✅ Website is healthy and accessible"
          else
            echo "❌ Website health check failed"
            exit 1
          fi

  # Cleanup old data files (keep last 30 days)
  cleanup:
    needs: deploy
    runs-on: ubuntu-latest
    if: github.event_name == 'schedule' && github.event.schedule == '0 23 * * *'  # Only on evening run
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        
      - name: Cleanup old data files
        run: |
          echo "🧹 Cleaning up old data files..."
          
          # Keep last 30 days of data
          find data/ -name "*.json" -type f -mtime +30 -delete || true
          find data/ -name "newspaper-*.json" -type f -mtime +30 -delete || true
          
          git config user.name "Daily Briefing Bot"
          git config user.email "bot@daily-briefing.local"
          git add data/
          
          if ! git diff --staged --quiet; then
            git commit -m "🧹 Cleanup: Remove data files older than 30 days"
            git push
          fi